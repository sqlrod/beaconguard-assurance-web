---
const { title = "BeaconGuard Assurance" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>

    <meta name="description" content="Deterministic control plane for regulated AI systems." />

    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>

  <body>
    <!-- Skip link for keyboard users -->
    <a href="#content" class="skip-link">Skip to content</a>

    <header class="site-header" role="banner">
      <div class="header-inner">
        <a href="/" class="brand" aria-label="BeaconGuard Assurance home">
          BeaconGuard Assurance
        </a>

        <nav class="header-nav" aria-label="Primary navigation">
          <a href="/" aria-current="page">Home</a>
          <a href="/docs">Docs</a>
          <a href="/docs/architecture">Architecture</a>
        </nav>
      </div>
    </header>

    <main id="content" role="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="footer-inner">
        <div class="footer-left">
          <strong>BeaconGuard Assurance</strong><br />
          Deterministic Control Plane for Regulated AI
        </div>

        <div class="footer-center">
          <span>Documentation Version: v0.1</span><br />
          <span>Last Updated: 2026</span>
        </div>

        <div class="footer-right">
          <a href="mailto:info@beaconguard.ai">Contact</a><br />
          <a href="/docs">Documentation</a>
        </div>
      </div>
    </footer>
  </body>
</html>
