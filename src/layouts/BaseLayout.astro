---
const {
  title = "BeaconGuard Assurance",
  description = "BeaconGuard is a deterministic control and evidence boundary for high-risk enterprise workflows. It returns explicit ALLOW or DENY results before governed execution and produces Verifiable Decision Records.",
} = Astro.props;
const currentPath = Astro.url.pathname;
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>

    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  </head>

  <body>
    <!-- Skip link for keyboard users -->
    <a href="#content" class="skip-link">Skip to content</a>

    <header class="site-header" role="banner">
      <div class="header-inner">
        <a href="/" class="brand" aria-label="BeaconGuard Assurance home">
            <img
              class="brand-logo"
              src="/beaconguard-master-logo.png"
              alt="BeaconGuard Assurance"
            />
        </a>

        <nav class="header-nav" aria-label="Primary navigation">
          <a href="/platform" aria-current={currentPath === "/platform" ? "page" : undefined}>Platform</a>
          <a href="/healthcare" aria-current={currentPath === "/healthcare" ? "page" : undefined}>Healthcare</a>
          <a href="/fintech" aria-current={currentPath === "/fintech" ? "page" : undefined}>Financial</a>
          <a href="/proof-evidence" aria-current={currentPath === "/proof-evidence" ? "page" : undefined}>Proof</a>
          <a href="/security" aria-current={currentPath === "/security" ? "page" : undefined}>Security</a>
          <a href="/design-partner-program" aria-current={currentPath === "/design-partner-program" ? "page" : undefined}>Controlled Evaluation</a>
          <a href="/contact" aria-current={currentPath === "/contact" ? "page" : undefined}>Contact</a>
        </nav>
      </div>
    </header>

    <main id="content" role="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="footer-inner">
        <div class="footer-left">
          <div class="footer-brand-lockup">
            <div class="footer-brand-mark">
              <img class="footer-brand-icon" src="/beaconguard-master-icon.png" alt="" aria-hidden="true" />
              <strong>BeaconGuard Assurance</strong>
            </div>
          </div>
        </div>

        <div class="footer-center">
          <p class="footer-slogan-line">Deterministic Control. Verifiable Decisions.</p>
          <p class="footer-slogan-line">The Control Boundary for AI Liability.</p>
        </div>

        <div class="footer-right">
          <a href="/contact">Contact</a><br />
          <a href="/docs">Technical Reference</a>
        </div>
      </div>
    </footer>
  </body>
</html>
