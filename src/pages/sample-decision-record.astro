---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sample Decision Record | BeaconGuard Assurance"
  description="A sanitized BeaconGuard Verifiable Decision Record sample showing DENY with APPROVAL_REQUIRED, release identity, and playbook identity."
>
  <section class="stack-section">
    <h1>Sample Decision Record</h1>
    <p class="lead">
      This sample illustrates the kinds of decision context BeaconGuard emits for reviewer analysis.
      It is an example Verifiable Decision Record, not a real customer record and not a claim that every deployment will expose fields in identical presentation form.
    </p>
  </section>

  <section class="stack-section">
    <h2>What this sample is for</h2>
    <ul>
      <li>Help reviewers understand what a Verifiable Decision Record contains</li>
      <li>Show how release_identity, playbook_identity, signed request context, and decision outcome are separated from downstream business records</li>
      <li>Support architecture, security, risk, and audit review</li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Sample fields</h2>
    <div class="sample-record sample-record--compact">
      <div class="sample-record-row">
        <span class="sample-record-label">Decision outcome</span>
        <span class="sample-record-value">DENY</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Reason code (illustrative)</span>
        <span class="sample-record-value">APPROVAL_REQUIRED</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">release_identity</span>
        <span class="sample-record-value">release.healthcare.ops.v12</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">playbook_identity</span>
        <span class="sample-record-value">playbook.healthcare.ops.summarize.v12</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Decision reason</span>
        <span class="sample-record-value">Required approval absent; governed execution prevented</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Request action</span>
        <span class="sample-record-value">AI-assisted operational summary request</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Actor type</span>
        <span class="sample-record-value">Regulated operations user</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Outcome</span>
        <span class="sample-record-value">Execution Prevented</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Review obligation</span>
        <span class="sample-record-value">Privacy governance notification (does not permit execution)</span>
      </div>
      <div class="sample-record-row">
        <span class="sample-record-label">Fail-closed result</span>
        <span class="sample-record-value">DENY before governed execution; no downstream call</span>
      </div>
    </div>
  </section>

  <section class="stack-section">
    <h2>What reviewers should notice</h2>
    <ul>
      <li>BeaconGuard records the Deterministic Decision Result, not the business transaction itself</li>
      <li>Runtime permission results are ALLOW or DENY only; absent approval is DENY, not a permission-to-execute review state</li>
      <li>release_identity and playbook_identity support reconstruction against the Active Verified Release</li>
      <li>A review obligation may notify governance; it does not change the DENY result</li>
      <li>Downstream systems remain responsible for business-state and transaction authority</li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Next step</h2>
    <div class="page-actions">
      <a class="btn-primary" href="/reviewer-kit">Return to Reviewer Kit</a>
      <a class="btn-secondary" href="/proof-evidence">View more evidence samples</a>
      <a class="btn-secondary" href="/trust-assurance">Review Trust Center</a>
    </div>
  </section>
</BaseLayout>
