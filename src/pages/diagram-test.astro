---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Diagram Test | BeaconGuard Assurance">
  <section class="diagram-test-page">
    <h1>BeaconGuard Control Boundary — Diagram Test</h1>
    <p>Deterministic Validation &amp; Policy Enforcement Sequence</p>

    <div
      class="mermaid-frame"
      style="padding:40px; border-radius:12px; overflow:visible;"
    >
      <div id="diagram-definition"></div>
    </div>
  </section>

  <script type="text/plain" id="diagram-source">
flowchart LR
subgraph External_Input ["Business Workflow (Outside Control Boundary)"]
    direction LR
    B1["Financial Application / Analyst Workflow<br/>• AML / Fraud Analyst<br/>• Case Review / Transaction Context<br/>• AI-Assisted Request Initiated"]
    B2["Compatibility Adapter (Optional)<br/>• Request Normalization<br/>• Schema Alignment<br/>• No Policy Authority"]
    B1 --> B2
end

subgraph Boundary ["BeaconGuard Deterministic Control Boundary"]
    direction LR
    B2 --> B3
    B3["Gateway Intake<br/>• Request Received<br/>• Immutable Capture Point"]
    B4["Canonical Request Validation<br/>• Structure Validation<br/>• Required Fields Present<br/>• Reject If Malformed"]
    B5["Trust / Signature Validation<br/>• Signature Verification<br/>• Source Authenticity<br/>• Key Validation"]
    B6["Replay / Freshness Check<br/>• Nonce / Timestamp Validation<br/>• Duplicate Prevention<br/>• Expiration Enforcement"]
    B7["Deterministic Policy Evaluation<br/>• Policy Conditions Evaluated<br/>• Context Sufficiency Checked<br/>• No Probabilistic Behavior"];
    B3 --> B4
    B4 --> B5
    B5 --> B6
    B6 --> B7

    B7 -->|"ALLOW"| B8
    B7 -->|"DENY (Fail-Closed)"| B9

    B8["AI / Model Endpoint<br/>• LLM / External Model<br/>• No Control Authority"]

    B9["Request Blocked Before Inference<br/>• No Model Execution<br/>• Explicit Denial Returned"]
    B8 -.->|"Model Output (Outside Control Boundary)"| B1

    B10["Decision Record / Reviewer-Visible Evidence<br/>• Request Hash<br/>• Policy Evaluated<br/>• Decision (ALLOW / DENY)<br/>• Timestamp<br/>• Signature / Integrity Proof"]
    B3 -.-> B10
    B4 -.-> B10
    B5 -.-> B10
    B6 -.-> B10
    B7 -.-> B10
    B8 -.-> B10
    B9 -.-> B10

    style Boundary fill:#f5f5f5,stroke:#333,stroke-width:3px
    style B7 fill:#ffffff,stroke:#333,stroke-width:2px
    style B8 fill:#e1f5fe,stroke:#01579b
    style B9 fill:#ffebee,stroke:#c62828,color:#c62828
    style B10 fill:#fff8e1,stroke:#ff8f00
end
</script>
</BaseLayout>

<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  mermaid.initialize({
    startOnLoad: true,
    theme: 'base',
    securityLevel: 'loose',
    flowchart: {
      useMaxWidth: true,
      htmlLabels: true,
      curve: 'linear'
    },
    themeVariables: {
      primaryColor: '#f5f5f5',
      primaryBorderColor: '#333',
      lineColor: '#333',
      fontFamily: 'Segoe UI, Arial, sans-serif'
    }
  });

  const diagramDefinition = (document.getElementById('diagram-source')?.textContent || '').trim();

  const diagramElement = document.getElementById('diagram-definition');
  if (diagramElement) {
    diagramElement.textContent = diagramDefinition;
    const { svg } = await mermaid.render('diagram-render', diagramDefinition);
    diagramElement.innerHTML = svg;
  }
</script>

<style>
  .diagram-test-page {
    max-width: none;
    width: 100vw;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-align: center;
    overflow: visible;
  }

  .diagram-test-page h1,
  .diagram-test-page p {
    margin: 0 0 1rem;
  }

  .mermaid-frame {
    margin-top: 1rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    overflow: visible;
    width: 100vw;
    box-sizing: border-box;
    padding: 0;
  }

  #diagram-definition {
    width: fit-content;
    transform: scale(10);
    transform-origin: top left;
    display: inline-block;
  }

  :global(#diagram-definition svg) {
    width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    .diagram-test-page {
      padding: 1.5rem 0.75rem 2rem;
      text-align: left;
    }

    .mermaid-frame[style] {
      width: calc(100vw - 32px);
      padding: 24px 14px;
    }
  }
</style>
