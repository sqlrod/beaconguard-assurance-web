---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Design Partner Program | BeaconGuard Assurance">
  <section>
    <h1>Design Partner Program</h1>
    <p>
      The program is for teams building enterprise AI systems that require stronger
      governance than application-level controls can provide alone.
    </p>
  </section>

  <section>
    <h2>Who We Partner With</h2>
    <ul>
      <li>Product groups deploying AI in regulated or high-trust environments.</li>
      <li>Platform teams shaping policy-driven runtime controls.</li>
      <li>Compliance and security teams designing evidence-ready operations.</li>
    </ul>
  </section>

  <section>
    <h2>What We Validate With Partners</h2>
    <div class="section-grid">
      <div class="content-card">
        <h3>Use-case boundaries</h3>
        <p>Where governance should intervene and what should remain out of scope.</p>
      </div>
      <div class="content-card">
        <h3>Policy posture</h3>
        <p>Operationally practical policy granularity across enterprise contexts.</p>
      </div>
      <div class="content-card">
        <h3>Evidence workflow</h3>
        <p>How governance decisions are reviewed during audit, operations, and incidents.</p>
      </div>
    </div>
  </section>

  <section>
    <h2>Intended Engagement</h2>
    <ul>
      <li>Initial alignment on governance outcomes and constraints.</li>
      <li>Review of deployment and integration posture.</li>
      <li>Focused feedback on trust boundary and evidence expectations.</li>
    </ul>
    <p>
      This is a collaboration-first process with practical validation, not a sales-only loop.
    </p>
  </section>

  <section>
    <h2>Contact the team</h2>
    <ul>
      <li><a href="/contact">Contact for design partner briefing</a></li>
    </ul>
    <div class="page-actions">
      <a class="btn-primary" href="/contact">Request partner briefing</a>
      <a class="btn-secondary" href="/platform">Review platform overview</a>
    </div>
  </section>
</BaseLayout>
