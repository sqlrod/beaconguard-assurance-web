---
import BaseLayout from "../layouts/BaseLayout.astro";

const allowRecord = `{
  "decision": "ALLOW",
  "request_id": "req_8f2a1c",
  "timestamp": "2026-07-20T18:04:11Z",
  "release_identity": "release.healthcare.ops.v12",
  "playbook_identity": "playbook.healthcare.ops.summarize.v12",
  "decision_context": {
    "workflow": "phi_operational_summary",
    "role": "care_ops_analyst",
    "approved_pathway": true
  },
  "trust_check": "PASS",
  "freshness_check": "PASS",
  "replay_check": "PASS",
  "outcome": "governed_execution_permitted",
  "evidence_id": "vdr_allow_8f2a1c"
}`;

const denyPlaybookRecord = `{
  "decision": "DENY",
  "reason_code": "APPROVAL_REQUIRED",
  "request_id": "req_3c91de",
  "timestamp": "2026-07-20T18:06:02Z",
  "release_identity": "release.healthcare.ops.v12",
  "playbook_identity": "playbook.healthcare.ops.summarize.v12",
  "decision_context": {
    "workflow": "phi_operational_summary",
    "role": "care_ops_analyst",
    "approved_pathway": false
  },
  "trust_check": "PASS",
  "freshness_check": "PASS",
  "replay_check": "PASS",
  "outcome": "execution_prevented",
  "evidence_id": "vdr_deny_3c91de"
}`;

const denyTrustRecord = `{
  "decision": "DENY",
  "request_id": "req_replay_77",
  "timestamp": "2026-07-20T18:09:44Z",
  "release_identity": "release.finops.dispute.v5",
  "playbook_identity": "playbook.finops.dispute.assist.v5",
  "decision_context": {
    "workflow": "dispute_review_assist",
    "role": "fraud_analyst",
    "approved_pathway": true
  },
  "trust_check": "PASS",
  "freshness_check": "PASS",
  "replay_check": "FAIL",
  "outcome": "execution_prevented",
  "evidence_id": "vdr_deny_replay_77"
}`;
---

<BaseLayout
  title="Proof and Evidence | Verifiable Decision Records"
  description="Illustrative Verifiable Decision Record samples showing ALLOW and DENY results, release identity, and trust, freshness, and replay check outcomes."
>
  <section class="stack-section">
    <h1>Proof and Evidence</h1>
    <p class="lead">
      These sanitized samples illustrate how Verifiable Decision Records can present deterministic ALLOW or DENY results. They are illustrative review examples, not a normative API schema and not production evidence from a customer environment.
    </p>
  </section>

  <section class="stack-section">
    <h2>ALLOW — controls satisfied</h2>
    <p>
      Trusted context and Active Verified Release requirements are satisfied. Governed execution may proceed. The Verifiable Decision Record preserves release identity and decision context.
    </p>
    <p class="sample-note">Illustrative sample — field names and values are for reviewer orientation only.</p>
    <pre class="code-block"><code>{allowRecord}</code></pre>
  </section>

  <section class="stack-section">
    <h2>DENY — playbook or control failure</h2>
    <p>
      The request fails a Compliance Playbook control, such as when a required approval is absent. Downstream execution is prevented. Governance or privacy review may follow from the Verifiable Decision Record; review does not change the DENY result or permit execution.
    </p>
    <p class="sample-note">
      Illustrative sample — <code>APPROVAL_REQUIRED</code> is shown as an example reason style authorized by the product contract; it is not published here as a complete public enum.
    </p>
    <pre class="code-block"><code>{denyPlaybookRecord}</code></pre>
  </section>

  <section class="stack-section">
    <h2>DENY — trust, freshness, or replay failure</h2>
    <p>
      Admission checks fail closed. When a replay or freshness check fails, the result is DENY before governed execution. The record captures check outcomes for reconstruction and audit support. No machine-style reason enum is asserted here beyond the binary decision and check results.
    </p>
    <p class="sample-note">Illustrative sample — field names and values are for reviewer orientation only.</p>
    <pre class="code-block"><code>{denyTrustRecord}</code></pre>
  </section>

  <section class="stack-section">
    <h2>What reviewers inspect</h2>
    <ul>
      <li>Whether the decision is ALLOW or DENY</li>
      <li>Whether explanatory reason text or an illustrative reason code clarifies the failure</li>
      <li>Whether release identity and playbook identity are present</li>
      <li>Whether trust, freshness, and replay checks are recorded</li>
      <li>Whether any follow-on governance review is separate from the permission result</li>
      <li>Whether evidence supports reconstruction without replacing systems of record</li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Related review material</h2>
    <div class="page-actions">
      <a class="btn-primary" href="/sample-decision-record">Sample Decision Record page</a>
      <a class="btn-secondary" href="/security">Security</a>
      <a class="btn-secondary" href="/trust-assurance">Trust Center</a>
      <a class="btn-secondary" href="/docs/compliance-audit">Compliance and Audit</a>
    </div>
  </section>

  <style>
    .sample-note {
      max-width: 720px;
      margin: 0 0 0.85rem;
      font-size: 0.9rem;
      color: var(--text-muted);
    }
  </style>
</BaseLayout>
