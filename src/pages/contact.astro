---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - BeaconGuard">
	<h1>Contact</h1>

	<p>
		BeaconGuard is ready for enterprise discussion on platform fit, design partner engagement,
		and deployment alignment. Use this direct channel to start a structured review.
	</p>

	<section class="contact-info">
		<h2>Primary contact channels</h2>
		<p><strong>General platform and governance intake:</strong></p>
		<p><a href="mailto:design@beaconguard.dev">design@beaconguard.dev</a></p>
		<p><strong>For urgent review requirements, include:</strong></p>
		<ul>
			<li>Organization type and environment context.</li>
			<li>Primary AI integration pattern.</li>
			<li>Compliance or assurance requirements in scope.</li>
		</ul>
		<p>
			<a class="btn-primary" href="mailto:design@beaconguard.dev?subject=BeaconGuard%20Inquiry">Start contact by email</a>
		</p>
	</section>

	<section>
		<h2>What we can discuss</h2>
		<ul>
			<li><a href="/platform">Platform scope and fit</a></li>
			<li><a href="/design-partner-program">Design partner engagement</a></li>
			<li><a href="/deployment">Deployment and integration approach</a></li>
		</ul>
	</section>
</BaseLayout>