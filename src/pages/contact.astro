---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | BeaconGuard Controlled Architecture Evaluation"
  description="Contact BeaconGuard to discuss a bounded Controlled Evaluation for ALLOW/DENY runtime control, Compliance Playbook mapping, and Verifiable Decision Records."
>
  <section class="stack-section">
    <h1>Request a Controlled Architecture Evaluation</h1>
    <p class="lead">
      Use this contact route to discuss a regulated workflow where AI or automation needs deterministic ALLOW or DENY enforcement at the Runtime Control Boundary before governed execution. BeaconGuard deploys alongside existing applications and does not require replacing systems of record.
    </p>
  </section>

  <section class="stack-section">
    <h2>What to include</h2>
    <ul>
      <li>Organization</li>
      <li>Industry</li>
      <li>Role</li>
      <li>Bounded workflow under consideration</li>
      <li>Intended evaluation type (architecture, security, evidence, or deployment fit)</li>
      <li>Approximate timeline</li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Do not submit</h2>
    <ul>
      <li>PHI</li>
      <li>Customer records</li>
      <li>Credentials</li>
      <li>Production secrets</li>
      <li>Confidential evidence packages</li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Inquiry type</h2>
    <ul>
      <li>Controlled Evaluation intake</li>
      <li>Architecture or security review questions</li>
      <li>Evidence and Trust Center clarification</li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Who should contact BeaconGuard</h2>
    <div class="section-grid section-grid--compact">
      <div class="content-card">
        <h3>Healthcare</h3>
        <p>Architecture, privacy, security, and operations owners of PHI-sensitive AI pathways.</p>
      </div>
      <div class="content-card">
        <h3>Financial services</h3>
        <p>Owners of AML, KYC, fraud, dispute, or customer-impacting recommendation workflows.</p>
      </div>
      <div class="content-card">
        <h3>Internal automation</h3>
        <p>Teams placing agents or automations against production systems under fail-closed controls.</p>
      </div>
    </div>
  </section>

  <section class="stack-section">
    <h2>Common review materials</h2>
    <ul>
      <li><a href="/docs/architecture">System Architecture</a></li>
      <li><a href="/how-it-works">How It Works</a></li>
      <li><a href="/proof-evidence">Proof and Evidence</a></li>
      <li><a href="/reviewer-kit">Reviewer Kit</a></li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Direct channel</h2>
    <p>
      <a class="btn-primary" href="mailto:architecture@beaconguardassurance.com?subject=Controlled%20Architecture%20Evaluation">architecture@beaconguardassurance.com</a>
    </p>
  </section>
</BaseLayout>
