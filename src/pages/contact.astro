        <ul>
          <li>AML platform teams</li>
          <li>Financial crime engineering</li>
          <li>Fraud technology teams</li>
          <li>Risk and compliance technology teams</li>
          <li>Security architecture teams</li>
        </ul>
      </div>
      <div class="content-card">
        <h3>Internal automation</h3>
        <ul>
          <li>IT operations</li>
          <li>Platform engineering</li>
          <li>Enterprise architecture</li>
          <li>AI governance and internal tooling teams</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="stack-section">
    <h2>Common Review Materials</h2>
    <ul>
