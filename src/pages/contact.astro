---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | BeaconGuard Assurance"
  description="Discuss regulated workflows where AI or automation needs policy enforcement, approval gates, or audit-ready evidence before execution."
>
  <h1>Contact</h1>

  <section class="stack-section">
    <p class="lead">
      Use this form to discuss a regulated workflow where AI or automation needs policy enforcement, approval gates, or audit-ready evidence before execution.
    </p>
  </section>

  <section class="stack-section">
    <h2>Who Should Reach Out</h2>
    <p>BeaconGuard is evaluated by:</p>
    <ul>
      <li>Healthcare compliance, privacy, or hospital operations evaluation teams</li>
      <li>Financial services workflow evaluation teams</li>
      <li>Security Architecture and enterprise risk engineering</li>
      <li>Compliance technology and audit leadership</li>
      <li>Internal automation and regulated operations teams</li>
    </ul>
  </section>

  <section class="stack-section what-to-expect">
    <h2>What to Expect</h2>
    <p>Initial conversations focus on:</p>
    <ul>
      <li>your current AI-assisted workflow</li>
      <li>where policy control, approval gates, privacy review, and audit requirements apply</li>
      <li>how BeaconGuard would enforce deterministic control before model execution</li>
    </ul>
    <p>No integration work is required for initial evaluation.</p>
  </section>

  <style>
    .what-to-expect ul {
      margin-top: 0.5rem;
      line-height: 1.5;
    }

    .what-to-expect li {
      line-height: 1.5;
      padding-top: 2px;
    }
  </style>

  <section class="stack-section">
    <p class="lead">
      Request a regulated workflow and control-boundary review with BeaconGuard.
      Conversations are structured around three paths:
      security/compliance review, design partner engagement, and technical architecture review.
    </p>

    <div class="page-actions">
      <a class="btn-primary" href="mailto:design@beaconguardassurance.com?subject=Technical%20Review%20Request">Request a Technical Review</a>
      <a class="btn-secondary" href="mailto:design@beaconguard.dev?subject=Design%20Partner%20Discussion">Start design partner discussion</a>
      <a class="btn-secondary" href="/reviewer-kit">Open the Reviewer Kit</a>
    </div>
  </section>

  <section class="stack-section">
    <h2>Common Review Materials</h2>
    <p>
      These review materials can be used to begin a self-serve evaluation before deeper engagement.
    </p>
    <ul>
      <li><a href="/docs/architecture">Architecture blueprint</a></li>
      <li><a href="/how-it-works">Reviewer walkthrough</a></li>
      <li><a href="/deployment">Deployment boundary review</a></li>
      <li><a href="/design-partner-program">Design partner briefing</a></li>
      <li><a href="/control-responsibility-matrix">Control responsibility matrix</a></li>
      <li><a href="/sample-decision-record">Sample decision record</a></li>
    </ul>
  </section>

  <section class="stack-section">
    <h2>Primary Discussions</h2>
    <div class="section-grid section-grid--compact">
      <div class="content-card">
        <h3>Healthcare / hospital operations evaluation</h3>
        <p><a href="/canonical-workflow">Review healthcare workflow examples</a></p>
      </div>
      <div class="content-card">
        <h3>Financial services workflow evaluation</h3>
        <p><a href="/canonical-workflow">Review financial workflow examples</a></p>
      </div>
      <div class="content-card">
        <h3>Security / compliance review</h3>
        <p><a href="/platform">Review platform scope and fit</a></p>
      </div>
      <div class="content-card">
        <h3>Design partner pathway</h3>
        <p><a href="/design-partner-program">Explore design partner engagement</a></p>
      </div>
      <div class="content-card">
        <h3>Technical architecture review</h3>
        <p><a href="/deployment">Discuss deployment and governance control architecture</a></p>
      </div>
    </div>
    <p class="muted-copy">
      Include your primary AI integration pattern and assurance requirements in your initial message.
    </p>
  </section>

  <section class="stack-section">
    <h2>Direct channel</h2>
    <p><a class="btn-primary" href="mailto:design@beaconguardassurance.com?subject=BeaconGuard%20Inquiry">design@beaconguardassurance.com</a></p>
  </section>
</BaseLayout>